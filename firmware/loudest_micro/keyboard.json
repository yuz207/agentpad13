{
    "$comment": "Loudest Micro Rev A - vial-qmk port. Pin map + LED chain order are frozen in docs/independent-design/phase0-layout-v2-notes.md (D1 top-band re-freeze, PCB 84.2x103.7). rgb_matrix.layout coordinates are generated by firmware/gen_led_layout.py (chain: 0-12 per-key SW1-SW13, 13 layer indicator flag, 14-23 underglow).",
    "keyboard_name": "Loudest Micro",
    "manufacturer": "Open Hardware",
    "maintainer": "work-loudest",
    "url": "https://github.com/work-loudest/loudest-micro",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "usb": {
        "vid": "0xFEED",
        "pid": "0x4C4D",
        "device_version": "0.0.1"
    },
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "encoder": true,
        "rgb_matrix": true,
        "joystick": true,
        "raw": true
    },
    "matrix_pins": {
        "direct": [
            ["GP0", "GP1", "GP2", "GP3"],
            ["GP4", "GP5", "GP6", "GP7"],
            ["GP8", "GP9", "GP10", "GP11"],
            ["GP12", "GP15", "GP16", null]
        ]
    },
    "$matrix_comment": "Row 3: [3,0]=SW13 2U (GP12), [3,1]=encoder push (GP15), [3,2]=TTP223 touch OUT (GP16, PCB straps AHLB active-low so it reads like a normal direct pin), [3,3]=unused.",
    "encoder": {
        "rotary": [
            {"pin_a": "GP13", "pin_b": "GP14"}
        ]
    },
    "$joystick_comment": "PLACEHOLDER calibration - 512 center, 0..1023 span. Real low/rest/high come from the Phase-1 ADC sweep (spec C1/C2). QMK native output is HID gamepad; arrow/scroll modes are custom code in loudest_micro.c (JS_MODE keycode).",
    "joystick": {
        "driver": "analog",
        "button_count": 0,
        "axes": {
            "x": {"input_pin": "GP26", "low": 0, "rest": 512, "high": 1023},
            "y": {"input_pin": "GP27", "low": 0, "rest": 512, "high": 1023}
        }
    },
    "ws2812": {
        "pin": "GP17",
        "driver": "vendor"
    },
    "$rgb_comment": "max_brightness cap 105/255 = USB 500 mA budget (24 LEDs x 36 mA full white + ~100 mA system, spec 3.6). Data line drives 5V LEDs through a populated SN74LVC1T45 level shifter (spec C3).",
