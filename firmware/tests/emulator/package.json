{
    "name": "agentpad13-emulator-smoke",
    "private": true,
    "description": "Boots the production UF2 in the rp2040js emulator and smoke-tests the Rev A pin map, key scan, WS2812 data pin, and raw HID protocol.",
    "scripts": {
        "get-bootrom": "./get-bootrom.sh",
        "smoke:default": "node runner.cjs ../../prebuilt/loudest_micro_default.uf2 04424c440018081f000000000000000000000000000000000000000000000000",
        "smoke:vial": "node runner.cjs ../../prebuilt/loudest_micro_vial.uf2 04424c440018081f000000000000000000000000000000000000000000000000"
    },
    "dependencies": {
        "rp2040js": "1.3.3"
    }
}
